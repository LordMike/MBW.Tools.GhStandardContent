{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/LordMike/MBW.Tools.GhStandardContent/master/spec/RepositoryConfig.json",
  "title": "GitHub standard-content repository configuration",
  "type": "object",
  "required": [
    "content",
    "repositories"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "content": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "repositories": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[^/\\s]+/[^/\\s]+$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "boolean"
        }
      }
    }
  }
}
